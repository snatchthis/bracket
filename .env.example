# Copy to .env and fill in. Used by docker-compose.prod.yml.
# Never commit the real .env.

# --- Public URL (must match your Traefik router host) ---
BRACKET_DOMAIN=bracket.example.com

# --- Image tag to pull from ghcr.io/snatchthis/bracket ---
# Set to a release tag (e.g. v1.2.3) for reproducible deploys; "latest" otherwise.
BRACKET_TAG=v0.1.1

# --- Traefik ---
# Name of the certresolver configured in your Traefik static config.
TRAEFIK_CERTRESOLVER=letsencrypt

# --- Secrets (generate strong, unique values) ---
# JWT signing key. Generate with: openssl rand -hex 32
JWT_SECRET=

# Postgres password. Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- Initial admin account (created on first start) ---
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=

# --- Registration ---
# Keep false on a private home-lab instance unless you want open sign-ups.
ALLOW_USER_REGISTRATION=false

# --- Optional ---
# SENTRY_DSN=
